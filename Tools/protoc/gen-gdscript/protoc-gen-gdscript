def _print_help() -> None:
    print(__doc__)
    print("Options:")
    print("  --proto_path=DIR    Directory containing .proto source files")
    print("  --gdscript_out=DIR  Output directory for generated *_pb.gd files")
    print("  --help, -h          Show this help message")
    print()
    print("Examples:")
    print("  # Standalone")
    print("  python3 protoc-gen-gdscript --proto_path=GameServer/proto \\")
    print("                              --gdscript_out=Engine/godot/project/proto/gen")
    print()
    print("  # Via protoc (plugin mode)")
    print("  protoc --plugin=protoc-gen-gdscript=Tools/protoc/gen-gdscript/protoc-gen-gdscript \\")
    print("         --gdscript_out=Engine/godot/project/proto/gen \\")
    print("         GameServer/proto/*.proto")


def main() -> None:
    argv = sys.argv[1:]

    if "--help" in argv or "-h" in argv:
        _print_help()
        sys.exit(0)

    if not argv:
        # No arguments: detect plugin mode from stdin
        if not sys.stdin.isatty():
            run_plugin_mode()
        else:
            _print_help()
            sys.exit(0)
        return

    # Standalone mode
    parser = argparse.ArgumentParser(
        prog="protoc-gen-gdscript",
        description="Generate GDScript proto classes from .proto files.",
        add_help=False,
    )
    parser.add_argument("--proto_path", required=True,
                        help="Directory containing .proto source files")
    parser.add_argument("--gdscript_out", required=True,
                        help="Output directory for generated *_pb.gd files")
    args, _unknown = parser.parse_known_args(argv)
    run_standalone(args.proto_path, args.gdscript_out)


if __name__ == "__main__":
    main()
